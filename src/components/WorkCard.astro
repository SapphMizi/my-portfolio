---
import type { Work } from '../lib/microcms';
import { parseTags } from '../lib/microcms';

interface Props {
  work: Work;
}

const { work } = Astro.props;
const techs = parseTags(work.tech_stack);
---

<article class="group bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden hover:border-violet-500/50 transition-all duration-300">
  {work.thumbnail && (
    <div class="aspect-video overflow-hidden">
      <img
        src={`${work.thumbnail.url}?w=640`}
        alt={work.title}
        width={640}
        height={360}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-5">
    <h3 class="font-semibold text-lg text-white mb-2">{work.title}</h3>
    {work.description && (
      <p class="text-zinc-400 text-sm mb-4 line-clamp-2">{work.description}</p>
    )}
    {techs.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-4">
        {techs.map((tech) => (
          <span class="px-2 py-0.5 bg-zinc-800 text-zinc-300 text-xs rounded-full">
            {tech}
          </span>
        ))}
      </div>
    )}
    <div class="flex items-center gap-4">
      <a
        href={`/works/${work.id}`}
        class="text-sm text-violet-400 hover:text-violet-300 transition-colors"
      >
        詳細を見る →
      </a>
      {work.demo_url && (
        <a
          href={work.demo_url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          Demo ↗
        </a>
      )}
      {work.github_url && (
        <a
          href={work.github_url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          GitHub ↗
        </a>
      )}
    </div>
  </div>
</article>
