---
import type { Work } from '../lib/microcms';
import { parseTags } from '../lib/microcms';

interface Props {
  work: Work;
}

const { work } = Astro.props;
const techs = parseTags(work.tech_stack);
---

<article
  class="group bg-cloud border border-wisteria/70 rounded-3xl overflow-hidden shadow-[var(--shadow-kawaii)] hover:shadow-[var(--shadow-kawaii-hover)] hover:-translate-y-1 transition-all duration-300"
>
  {work.thumbnail && (
    <div class="aspect-video overflow-hidden">
      <img
        src={`${work.thumbnail.url}?w=640`}
        alt={work.title}
        width={640}
        height={360}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-5">
    <h3 class="font-display font-bold text-lg text-ink mb-2 text-balance">{work.title}</h3>
    {work.description && (
      <p class="text-muted text-sm mb-4 line-clamp-2 text-pretty">{work.description}</p>
    )}
    {techs.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-4">
        {techs.map((tech) => (
          <span class="px-2.5 py-0.5 bg-petal text-lavender text-xs rounded-full border border-blossom/60">
            {tech}
          </span>
        ))}
      </div>
    )}
    <div class="flex items-center gap-4">
      <a
        href={`/works/${work.id}`}
        class="text-sm font-medium text-lavender hover:text-sakura transition-colors"
      >
        詳細を見る →
      </a>
      {work.demo_url && (
        <a
          href={work.demo_url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-muted hover:text-sakura transition-colors"
        >
          Demo ↗
        </a>
      )}
      {work.github_url && (
        <a
          href={work.github_url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-muted hover:text-sakura transition-colors"
        >
          GitHub ↗
        </a>
      )}
    </div>
  </div>
</article>
