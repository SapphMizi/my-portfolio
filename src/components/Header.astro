---
import { siteConfig } from '../config';

const navLinks = [
  { label: 'Works', href: '/works' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/#about' },
];
---

<header class="sticky top-0 z-50 border-b border-border bg-night/80 backdrop-blur-sm">
  <nav class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="font-display font-bold text-lg text-mist hover:text-lavender transition-colors">
      {siteConfig.name}
    </a>
    <ul class="flex gap-6">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-haze hover:text-mist text-sm transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
