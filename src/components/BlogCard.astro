---
import type { Blog } from '../lib/microcms';

interface Props {
  blog: Blog;
}

const { blog } = Astro.props;
const date = new Date(blog.publishedAt).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group flex gap-4 p-4 bg-twilight border border-border rounded-xl hover:border-lavender/50 transition-all duration-300">
  {blog.thumbnail && (
    <div class="shrink-0 w-24 h-24 rounded-lg overflow-hidden">
      <img
        src={`${blog.thumbnail.url}?w=200`}
        alt={blog.title}
        width={96}
        height={96}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  )}
  <div class="min-w-0 flex flex-col justify-center">
    <div class="flex items-center gap-2 mb-1">
      <time class="text-dim text-xs">{date}</time>
      {blog.category && (
        <span class="px-2 py-0.5 bg-sakura/20 text-sakura text-xs rounded-full">
          {blog.category}
        </span>
      )}
    </div>
    <h3 class="font-medium text-mist group-hover:text-lavender transition-colors line-clamp-2">
      <a href={`/blog/${blog.id}`}>{blog.title}</a>
    </h3>
  </div>
</article>
