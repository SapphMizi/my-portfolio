---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Next.js の <Head> に相当する props を受け取る
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ポートフォリオ' } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="bg-cream text-ink min-h-dvh flex flex-col">
    <Header />
    <main class="flex-1">
      <!-- <slot /> は Next.js の {children} に相当 -->
      <slot />
    </main>
    <Footer />
  </body>
</html>
