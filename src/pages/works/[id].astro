---
import Layout from '../../layouts/Layout.astro';
import { listWorks, parseTags, type Work } from '../../lib/microcms';

// Next.js の generateStaticParams に相当
// ビルド時に全 Work の ID を収集し、各ページを静的生成する
export async function getStaticPaths() {
  const works = await listWorks();
  return works.map((work) => ({
    params: { id: work.id },
    props: { work },
  }));
}

interface Props {
  work: Work;
}

const { work } = Astro.props;
const techs = parseTags(work.tech_stack);
const tags = parseTags(work.tags);
const date = new Date(work.publishedAt).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${work.title} | Works`} description={work.description}>
  <div class="max-w-3xl mx-auto px-4 py-16">

    <a href="/works" class="inline-flex items-center gap-1 text-muted hover:text-lavender text-sm transition-colors mb-8">
      ← Works 一覧へ
    </a>

    <h1 class="font-display text-3xl md:text-4xl font-bold text-ink mb-3 text-balance">{work.title}</h1>
    <time class="text-faint text-sm">{date}</time>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-4">
        {tags.map((tag) => (
          <span class="px-2.5 py-0.5 bg-petal text-lavender text-xs rounded-full border border-wisteria">{tag}</span>
        ))}
      </div>
    )}

    {work.thumbnail && (
      <div class="mt-8 rounded-3xl overflow-hidden shadow-[var(--shadow-kawaii)]">
        <img
          src={`${work.thumbnail.url}?w=960`}
          alt={work.title}
          width={960}
          height={540}
          class="w-full h-auto"
        />
      </div>
    )}

    {work.description && (
      <p class="mt-8 text-ink leading-relaxed text-lg text-pretty">{work.description}</p>
    )}

    {techs.length > 0 && (
      <div class="mt-8">
        <h2 class="font-display text-lg font-bold text-ink mb-3">使用技術</h2>
        <div class="flex flex-wrap gap-2">
          {techs.map((tech) => (
            <span class="px-3 py-1 bg-petal border border-wisteria text-lavender text-sm rounded-full">
              {tech}
            </span>
          ))}
        </div>
      </div>
    )}

    <div class="mt-10 flex gap-4">
      {work.demo_url && (
        <a
          href={work.demo_url}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-2.5 bg-gradient-to-r from-lavender to-sakura text-white font-bold rounded-full shadow-[var(--shadow-kawaii)] hover:scale-105 transition-transform"
        >
          Demo を見る ↗
        </a>
      )}
      {work.github_url && (
        <a
          href={work.github_url}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-2.5 bg-cloud border border-wisteria text-ink hover:text-lavender font-bold rounded-full shadow-[var(--shadow-kawaii)] hover:scale-105 transition-transform"
        >
          GitHub ↗
        </a>
      )}
    </div>

  </div>
</Layout>
