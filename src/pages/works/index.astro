---
import Layout from '../../layouts/Layout.astro';
import WorkCard from '../../components/WorkCard.astro';
import { listWorks } from '../../lib/microcms';

const works = await listWorks();
---

<Layout title="Works | Portfolio">
  <div class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold text-white mb-2">Works</h1>
    <p class="text-zinc-400 mb-10">制作物・ポートフォリオ</p>

    {works.length > 0 ? (
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {works.map((work) => <WorkCard work={work} />)}
      </div>
    ) : (
      <div class="text-center py-20 border border-dashed border-zinc-800 rounded-xl">
        <p class="text-zinc-500">microCMS に Works を追加すると表示されます</p>
      </div>
    )}
  </div>
</Layout>
