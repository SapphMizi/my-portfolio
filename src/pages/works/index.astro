---
import Layout from '../../layouts/Layout.astro';
import WorkCard from '../../components/WorkCard.astro';
import { listWorks } from '../../lib/microcms';

const works = await listWorks();
---

<Layout title="Works | Portfolio">
  <div class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="font-display text-4xl font-bold text-ink mb-2 text-balance flex items-center gap-2">
      <span class="text-sakura">✿</span>Works
    </h1>
    <p class="text-muted mb-10">制作物・ポートフォリオ</p>

    {works.length > 0 ? (
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {works.map((work) => <WorkCard work={work} />)}
      </div>
    ) : (
      <div class="text-center py-20 bg-petal/50 border border-dashed border-blossom rounded-3xl">
        <p class="text-muted">microCMS に Works を追加すると表示されます</p>
      </div>
    )}
  </div>
</Layout>
