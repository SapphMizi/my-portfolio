---
import Layout from '../../layouts/Layout.astro';
import { listBlogs, parseTags, type Blog } from '../../lib/microcms';

export async function getStaticPaths() {
  const blogs = await listBlogs();
  return blogs.map((blog) => ({
    params: { id: blog.id },
    props: { blog },
  }));
}

interface Props {
  blog: Blog;
}

const { blog } = Astro.props;
const tags = parseTags(blog.tags);
const date = new Date(blog.publishedAt).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${blog.title} | Blog`}>
  <div class="max-w-3xl mx-auto px-4 py-16">

    <a href="/blog" class="inline-flex items-center gap-1 text-muted hover:text-lavender text-sm transition-colors mb-8">
      ← Blog 一覧へ
    </a>

    <header class="mb-8">
      <div class="text-faint text-sm mb-3">
        {blog.category && <span class="text-sakura font-medium">{blog.category}</span>}
        <span>{blog.category && ' · '}{date}</span>
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-ink leading-snug text-balance">{blog.title}</h1>
      {tags.length > 0 && (
        <p class="text-sm text-muted mt-4">{tags.join(', ')}</p>
      )}
    </header>

    {blog.thumbnail && (
      <div class="mb-10 rounded-3xl overflow-hidden shadow-[var(--shadow-kawaii)]">
        <img
          src={`${blog.thumbnail.url}?w=960`}
          alt={blog.title}
          width={960}
          height={540}
          class="w-full h-auto"
        />
      </div>
    )}

    <!--
      microCMS のリッチエディタは HTML で返ってくる。
      set:html は Next.js の dangerouslySetInnerHTML に相当。
      prose は @tailwindcss/typography のリッチテキスト整形クラス（ライト用）。
    -->
    <div
      class="prose prose-zinc prose-headings:font-display prose-h1:text-2xl prose-h2:text-xl prose-h3:text-lg prose-a:text-lavender prose-a:no-underline hover:prose-a:text-sakura max-w-none"
      set:html={blog.content}
    />

  </div>
</Layout>
