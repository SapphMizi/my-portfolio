---
import Layout from '../layouts/Layout.astro';
import WorkCard from '../components/WorkCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { listWorks, listBlogs } from '../lib/microcms';
import { siteConfig, skills } from '../config';

const [featuredWorks, latestBlogs] = await Promise.all([
  listWorks(3),
  listBlogs(3),
]);

const skillCategories = skills.reduce<Record<string, string[]>>((acc, s) => {
  (acc[s.category] ??= []).push(s.name);
  return acc;
}, {});
---

<Layout title={`${siteConfig.name} | Portfolio`} description={siteConfig.bio}>

  <!-- ===== Hero ===== -->
  <section class="min-h-screen flex items-center justify-center px-4 relative overflow-hidden">
    <!-- バナーの水彩ブロブを暗背景に再現 -->
    <div class="absolute -top-32 -left-32 w-[500px] h-[500px] bg-lavender/10 rounded-full blur-3xl pointer-events-none" />
    <div class="absolute -bottom-20 -right-20 w-[400px] h-[400px] bg-sakura/10 rounded-full blur-3xl pointer-events-none" />
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 bg-gold/5 rounded-full blur-2xl pointer-events-none" />

    <div class="max-w-3xl text-center relative">
      <p class="text-lavender font-mono text-sm mb-4 tracking-widest">Hello, I'm</p>
      <h1 class="text-5xl md:text-7xl font-bold text-mist mb-4 tracking-tight">
        {siteConfig.name}
      </h1>
      <p class="text-xl md:text-2xl text-haze mb-4">{siteConfig.title}</p>
      <p class="text-haze max-w-xl mx-auto mb-10 leading-relaxed">
        {siteConfig.bio}
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href="/works"
          class="px-6 py-3 bg-gradient-to-r from-lavender to-sakura text-night font-semibold rounded-lg hover:opacity-90 transition-opacity"
        >
          Works を見る
        </a>
        <a
          href="/#about"
          class="px-6 py-3 border border-border hover:border-lavender text-haze hover:text-mist font-medium rounded-lg transition-colors"
        >
          About
        </a>
      </div>
    </div>
  </section>

  <!-- ===== Featured Works ===== -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-mist">Featured Works</h2>
      <a href="/works" class="text-sm text-lavender hover:text-sakura transition-colors">
        すべて見る →
      </a>
    </div>

    {featuredWorks.length > 0 ? (
      <div class="grid md:grid-cols-3 gap-6">
        {featuredWorks.map((work) => <WorkCard work={work} />)}
      </div>
    ) : (
      <p class="text-dim text-center py-12 border border-dashed border-border rounded-xl">
        Works は microCMS に追加後に表示されます
      </p>
    )}
  </section>

  <!-- ===== Latest Blog ===== -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-mist">Latest Blog</h2>
      <a href="/blog" class="text-sm text-lavender hover:text-sakura transition-colors">
        すべて見る →
      </a>
    </div>

    {latestBlogs.length > 0 ? (
      <div class="flex flex-col gap-4">
        {latestBlogs.map((blog) => <BlogCard blog={blog} />)}
      </div>
    ) : (
      <p class="text-dim text-center py-12 border border-dashed border-border rounded-xl">
        Blog は microCMS に追加後に表示されます
      </p>
    )}
  </section>

  <!-- ===== About + Skills ===== -->
  <section id="about" class="max-w-5xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-mist mb-8">About</h2>
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <p class="text-haze leading-relaxed mb-6">
          {siteConfig.bio}
        </p>
        <div class="flex gap-4">
          <a
            href={siteConfig.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-dim hover:text-lavender transition-colors"
          >
            GitHub ↗
          </a>
          <a
            href={`mailto:${siteConfig.email}`}
            class="text-sm text-dim hover:text-lavender transition-colors"
          >
            Contact ↗
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-mist mb-4">Skills</h3>
        <div class="space-y-4">
          {Object.entries(skillCategories).map(([category, names]) => (
            <div>
              <p class="text-xs text-dim uppercase tracking-widest mb-2">{category}</p>
              <div class="flex flex-wrap gap-2">
                {names.map((name) => (
                  <span class="px-3 py-1 bg-twilight border border-border text-haze text-sm rounded-lg">
                    {name}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

</Layout>
