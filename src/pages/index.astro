---
import Layout from '../layouts/Layout.astro';
import WorkCard from '../components/WorkCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { listWorks, listBlogs } from '../lib/microcms';
import { siteConfig, skills, musicActivities } from '../config';

const [featuredWorks, latestBlogs] = await Promise.all([
  listWorks(3),
  listBlogs(3),
]);

const skillCategories = skills.reduce<Record<string, string[]>>((acc, s) => {
  (acc[s.category] ??= []).push(s.name);
  return acc;
}, {});
---

<Layout title={`${siteConfig.name} | Portfolio`} description={siteConfig.bio}>

  <!-- ===== Hero ===== -->
  <section class="relative overflow-hidden min-h-dvh flex items-center justify-center px-4">
    <!-- 水彩ブロブ（バナーのパステルを白背景に展開） -->
    <div class="absolute -top-24 -left-24 w-[460px] h-[460px] bg-wisteria/50 rounded-full blur-3xl pointer-events-none" />
    <div class="absolute -bottom-28 -right-20 w-[420px] h-[420px] bg-blossom/50 rounded-full blur-3xl pointer-events-none" />
    <div class="absolute top-1/3 right-1/4 w-40 h-40 bg-gold/15 rounded-full blur-3xl pointer-events-none" />

    <div class="max-w-3xl text-center relative">
      <h1 class="font-display text-5xl md:text-7xl font-bold text-ink mb-5 tracking-tight text-balance animate-fade-down animate-duration-700">
        {siteConfig.name}
      </h1>
      <!-- 肩書きをパステルのピル型に -->
      <p class="inline-block px-5 py-2 mb-6 rounded-full bg-cloud border border-wisteria text-lavender font-medium shadow-[var(--shadow-kawaii)] animate-fade-down animate-duration-700 animate-delay-100">
        {siteConfig.title}
      </p>
      <p class="text-muted max-w-xl mx-auto mb-10 leading-relaxed text-pretty animate-fade-down animate-duration-700 animate-delay-200">
        {siteConfig.bio}
      </p>
      <div class="flex gap-4 justify-center flex-wrap animate-fade-down animate-duration-700 animate-delay-300">
        <a
          href="/works"
          class="px-7 py-3 bg-gradient-to-r from-lavender to-sakura text-white font-bold rounded-full shadow-[var(--shadow-kawaii-hover)] hover:scale-105 transition-transform"
        >
          Works を見る ♪
        </a>
        <a
          href="/#about"
          class="px-7 py-3 bg-cloud border border-wisteria text-ink hover:text-lavender font-bold rounded-full shadow-[var(--shadow-kawaii)] hover:scale-105 transition-transform"
        >
          About
        </a>
      </div>
    </div>
  </section>

  <!-- ===== Featured Works ===== -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="flex items-end justify-between mb-8">
      <h2 class="font-display text-3xl font-bold text-ink text-balance flex items-center gap-2">
        <span class="text-sakura">✿</span>Works
      </h2>
      <a href="/works" class="text-sm font-medium text-lavender hover:text-sakura transition-colors">
        すべて見る →
      </a>
    </div>

    {featuredWorks.length > 0 ? (
      <div class="grid md:grid-cols-3 gap-6">
        {featuredWorks.map((work) => <WorkCard work={work} />)}
      </div>
    ) : (
      <div class="text-center py-16 bg-petal/50 border border-dashed border-blossom rounded-3xl">
        <p class="text-muted text-pretty">Works は microCMS に追加すると表示されます</p>
      </div>
    )}
  </section>

  <!-- ===== Latest Blog ===== -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="flex items-end justify-between mb-8">
      <h2 class="font-display text-3xl font-bold text-ink text-balance flex items-center gap-2">
        <span class="text-sakura">✎</span>Blog
      </h2>
      <a href="/blog" class="text-sm font-medium text-lavender hover:text-sakura transition-colors">
        すべて見る →
      </a>
    </div>

    {latestBlogs.length > 0 ? (
      <div class="flex flex-col gap-4">
        {latestBlogs.map((blog) => <BlogCard blog={blog} />)}
      </div>
    ) : (
      <div class="text-center py-16 bg-petal/50 border border-dashed border-blossom rounded-3xl">
        <p class="text-muted text-pretty">Blog は microCMS に追加すると表示されます</p>
      </div>
    )}
  </section>

  <!-- ===== About + Skills + Music ===== -->
  <section id="about" class="max-w-5xl mx-auto px-4 py-16">
    <h2 class="font-display text-3xl font-bold text-ink mb-10 text-balance flex items-center gap-2">
      <span class="text-sakura">❀</span>About
    </h2>
    <div class="grid md:grid-cols-2 gap-8">

      <!-- Bio -->
      <div class="bg-cloud border border-wisteria/70 rounded-3xl p-6 shadow-[var(--shadow-kawaii)]">
        <p class="text-ink leading-relaxed mb-6 text-pretty">
          {siteConfig.bio}
        </p>
        <div class="flex gap-4">
          <a
            href={siteConfig.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub プロフィール（新しいタブで開く）"
            class="text-sm font-medium text-lavender hover:text-sakura transition-colors"
          >
            GitHub ↗
          </a>
          <a
            href={`mailto:${siteConfig.email}`}
            aria-label="メールで連絡する"
            class="text-sm font-medium text-lavender hover:text-sakura transition-colors"
          >
            Contact ↗
          </a>
        </div>
      </div>

      <div class="space-y-6">
        <!-- Programming Skills -->
        <div class="bg-cloud border border-wisteria/70 rounded-3xl p-6 shadow-[var(--shadow-kawaii)]">
          <h3 class="font-display text-lg font-bold text-ink mb-4 flex items-center gap-2">
            <span class="text-lavender">⌨</span>Programming
          </h3>
          <div class="space-y-3">
            {Object.entries(skillCategories).map(([category, names]) => (
              <div>
                <p class="text-xs text-faint uppercase tracking-widest mb-2">{category}</p>
                <div class="flex flex-wrap gap-2">
                  {names.map((name) => (
                    <span class="px-3 py-1 bg-petal text-lavender text-sm rounded-full border border-wisteria">
                      {name}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Music Activities -->
        <div class="bg-cloud border border-wisteria/70 rounded-3xl p-6 shadow-[var(--shadow-kawaii)]">
          <h3 class="font-display text-lg font-bold text-ink mb-4 flex items-center gap-2">
            <span class="text-sakura">♪</span>Music
          </h3>
          <div class="space-y-3">
            {musicActivities.map((activity) => (
              <div class="p-4 bg-petal/60 border border-blossom/60 rounded-2xl">
                <p class="text-ink font-medium mb-2">{activity.description}</p>
                {activity.genres.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {activity.genres.map((genre) => (
                      <span class="px-2.5 py-0.5 bg-sakura/15 text-sakura text-xs rounded-full">
                        {genre}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>
